PORT=5000
# Browser origin(s) allowed by CORS — use your Vercel URL in production (trailing slash is ok locally; server normalizes)
CLIENT_URL=http://localhost:5173
# Optional: comma-separated list, e.g. https://hrms-theta-two.vercel.app,https://www.example.com
# CLIENT_URLS=
# Set true on Render if you use many *.vercel.app preview URLs (any Vercel subdomain can call the API)
# CORS_ALLOW_VERCEL=false
DATABASE_URL=postgresql://postgres.[YOUR-PROJECT-REF]:[YOUR-PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?sslmode=require
DATABASE_SSL=true
JWT_SECRET=replace_with_a_strong_secret
JWT_EXPIRES_IN=1d
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxx
# Optional; default is onboarding@resend.dev (Resend test sender)
# RESEND_FROM=onboarding@resend.dev
